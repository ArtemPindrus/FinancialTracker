<UserControl
    x:Class="FinancialTracker.Views.UploadConnectingView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:FinancialTracker.ViewModels"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:UploadConnectingViewModel"
    mc:Ignorable="d">
    <StackPanel Orientation="Vertical">
        <TextBlock Text="Connecting..." />
        <Button Command="{Binding CancelConnectionCommand}" Content="Cancel" />
    </StackPanel>
</UserControl>
